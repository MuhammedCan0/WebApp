@startuml Login-Prozess
title Sequenzdiagramm: Login-Prozess

skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2
skinparam participantPadding 20

actor "Client" as Client
participant "Gateway\n(8080)" as Gateway
participant "Auth-Service\n(8085)" as Auth
participant "User-Service\n(8081)" as User
database "Auth-DB" as AuthDB
database "User-DB" as UserDB

== Login ==

Client -> Gateway: POST /api/auth/login\n{email, password}
activate Gateway

Gateway -> Auth: POST /api/v1/auth/login\n{email, password}
activate Auth

Auth -> AuthDB: findByEmail(email)
AuthDB --> Auth: AuthCredentials

alt Credentials nicht gefunden
    Auth --> Gateway: 401 Unauthorized
    Gateway --> Client: 401 Unauthorized
else Passwort falsch
    Auth -> Auth: BCrypt.matches(password, hash)
    Auth --> Gateway: 401 Unauthorized
    Gateway --> Client: 401 Unauthorized
else Credentials gültig
    Auth -> Auth: BCrypt.matches(password, hash) ✓
    
    Auth -> User: GET /internal/by-mn/{matrikelnummer}\n(X-Service-API-Key)
    activate User
    User -> UserDB: findByMatrikelnummer()
    UserDB --> User: User
    User --> Auth: User {roles, tenantIds, status}
    deactivate User
    
    alt User Status != ACTIVE
        Auth --> Gateway: 403 Forbidden\n"User nicht aktiv"
        Gateway --> Client: 403 Forbidden
    else User aktiv
        Auth -> Auth: JWT generieren\n(sub, email, roles, tenantIds,\nmatrikelnummer, 1h Gültigkeit)
        Auth --> Gateway: 200 OK\n{token, userId, roles, expiresAt}
        deactivate Auth
        Gateway --> Client: 200 OK\n{token, userId, roles, expiresAt}
    end
end

deactivate Gateway

@enduml

